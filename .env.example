# ── Optional: Azure subscription ───────────────────────────────────────────────
# Azure subscription that will host the ephemeral ODCR probe resources.
# If not set, the API auto-discovers from Azure CLI or accepts per-request override.
# AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ── Optional: resource group for probe resources ───────────────────────────────
# Will be created automatically if it does not exist.
# Default: az-cap-probe-rg
# AZURE_PROBE_RESOURCE_GROUP=az-cap-probe-rg

# ── Optional: service-principal authentication ────────────────────────────────
# If not set, DefaultAzureCredential falls back to Azure CLI / Managed Identity.
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_SECRET=<your-client-secret>

# ── Optional: user-assigned managed identity ──────────────────────────────────
# Required when using a user-assigned managed identity on Azure Function Apps.
# Set to the Client ID of the identity. Leave empty for system-assigned.
# AZURE_MANAGED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ── Optional: batch concurrency ───────────────────────────────────────────────
# Number of parallel ODCR probes for the /batch endpoint.
# Default: 3
# BATCH_CONCURRENCY=3
